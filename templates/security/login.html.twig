{% extends 'base.html.twig' %}

{% block title %}{{ 'login.page_title'|trans }}{% endblock %}

{% block body %}
<div class="login-wrapper">
    <div class="login-card">
        {{ include('_brand.html.twig', {brand_class: 'card-brand'}) }}

        <div style="display:flex; justify-content:flex-end; gap:.5rem; margin-bottom:1rem;">
            {{ include('_controls.html.twig') }}
        </div>

        <h1>{{ 'login.heading'|trans }}</h1>

        {% if error %}
            <div class="alert alert-error">
                {{ error.messageKey|trans(error.messageData, 'security') }}
            </div>
        {% endif %}

        {% if app.user %}
            <div class="alert alert-info">
                {{ 'login.already_connected_prefix'|trans }} {{ app.user.userIdentifier }}.
                <a href="{{ path('app_logout') }}">{{ 'login.logout_link'|trans }}</a>
            </div>
        {% endif %}

        <form action="{{ path('app_login') }}" method="post">
            <div class="form-group">
                <label for="inputEmail">{{ 'login.email_label'|trans }}</label>
                <input
                    type="email"
                    id="inputEmail"
                    name="_username"
                    value="{{ last_username }}"
                    autocomplete="email"
                    required
                    autofocus
                    placeholder="email@exemple.com"
                >
            </div>

            <div class="form-group">
                <label for="inputPassword">{{ 'login.password_label'|trans }}</label>
                <input
                    type="password"
                    id="inputPassword"
                    name="_password"
                    autocomplete="current-password"
                    required
                    placeholder="••••••••"
                >
            </div>

            <div class="form-check">
                <input type="checkbox" id="remember_me" name="_remember_me">
                <label for="remember_me">{{ 'login.remember_me'|trans }}</label>
            </div>

            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            <button type="submit" class="btn-submit">{{ 'login.submit'|trans }}</button>
        </form>

        <p class="register-link">
            {{ 'login.no_account'|trans }} <a href="{{ path('app_register') }}">{{ 'login.create_account'|trans }}</a>
        </p>
    </div>
</div>
{% endblock %}
