{% extends 'base.html.twig' %}

{% block title %}{{ 'home.page_title'|trans }}{% endblock %}

{% block body %}
<div class="home-container">

    <header class="home-header">
        <h1>{{ include('_brand.html.twig') }}</h1>
        <nav class="home-nav">
            {% if app.user %}
                <span style="color:var(--text-3); font-size:0.85rem;">
                    {{ 'nav.connected_as'|trans }} <strong style="color:var(--text-1);">{{ app.user.userIdentifier }}</strong>
                    {% if is_granted('ROLE_ADMIN') %}
                        <span class="badge-admin">{{ 'admin.role_admin'|trans }}</span>
                    {% endif %}
                </span>
                <a href="{{ path('app_profile') }}" class="btn btn-secondary">{{ 'nav.my_profile'|trans }}</a>
                <a href="{{ path('app_product_new') }}" class="btn btn-primary">{{ 'nav.publish_listing'|trans }}</a>
                <a href="{{ path('app_cart_show') }}" class="btn btn-secondary">{{ 'nav.my_cart'|trans }}</a>
                {% if is_granted('ROLE_ADMIN') %}
                    <a href="{{ path('app_admin_dashboard') }}" class="btn btn-secondary">{{ 'nav.administration'|trans }}</a>
                {% endif %}
                <a href="{{ path('app_logout') }}" class="btn btn-danger">{{ 'nav.logout'|trans }}</a>
            {% else %}
                <a href="{{ path('app_login') }}" class="btn btn-primary">{{ 'nav.login'|trans }}</a>
            {% endif %}
            {{ include('_controls.html.twig') }}
        </nav>
    </header>

    <main class="home-main">

        {# Flash messages #}
        {% for message in app.flashes('success') %}
            <div class="flash-success">{{ message }}</div>
        {% endfor %}
        {% for message in app.flashes('error') %}
            <div class="flash-error">{{ message }}</div>
        {% endfor %}

        <div class="home-content-header">
            {% set hasFilters = filters.name or filters.category or filters.priceMin or filters.priceMax or filters.stockMin or filters.stockMax %}

            <div style="display:flex; align-items:baseline; gap:1rem; margin-bottom:0.6rem; flex-wrap:wrap;">
                <h2 style="margin:0; font-size:1.4rem; color:var(--text-1);">{{ 'home.items_for_sale'|trans }}</h2>
                {% if hasFilters %}
                    <span class="filter-active-info" style="margin-bottom:0;">
                        <strong>{{ products|length }}</strong>&nbsp;{{ products|length != 1 ? 'home.results_plural'|trans : 'home.results_singular'|trans }}
                        <a href="{{ path('app_home') }}" class="filter-reset-link">{{ 'home.clear_filters'|trans }}</a>
                    </span>
                {% endif %}
            </div>

            <div class="stock-legend">
                <span class="legend-item legend-low">{{ 'home.legend_low_stock'|trans }}</span>
                <span class="legend-item legend-out">{{ 'home.legend_out_of_stock'|trans }}</span>
            </div>
        </div>

        <form method="get" action="{{ path('app_home') }}" id="filter-form">
                <table class="product-table">
                    <colgroup>
                        <col class="col-name">
                        <col class="col-category">
                        <col class="col-stock">
                        <col class="col-price">
                        <col class="col-description">
                    </colgroup>
                    <thead>
                        <tr>
                            <th>{{ 'home.col_name'|trans }}</th>
                            <th>{{ 'home.col_category'|trans }}</th>
                            <th>{{ 'home.col_stock'|trans }}</th>
                            <th>{{ 'home.col_price'|trans }}</th>
                            <th>{{ 'home.col_description'|trans }}</th>
                        </tr>
                        <tr class="filter-row">
                            <th>
                                <input type="text" name="name" value="{{ filters.name }}" placeholder="{{ 'home.filter_search_placeholder'|trans }}" class="filter-input">
                            </th>
                            <th>
                                <select name="category" class="filter-input">
                                    <option value="">{{ 'home.filter_all_categories'|trans }}</option>
                                    {% for cat in categories %}
                                        <option value="{{ cat.id }}" {% if filters.category == cat.id %}selected{% endif %}>{{ cat.name }}</option>
                                    {% endfor %}
                                </select>
                            </th>
                            <th>
                                <div class="filter-range">
                                    <input type="number" name="stockMin" value="{{ filters.stockMin }}" placeholder="Min" class="filter-input filter-input-half" min="0">
                                    <input type="number" name="stockMax" value="{{ filters.stockMax }}" placeholder="Max" class="filter-input filter-input-half" min="0">
                                </div>
                            </th>
                            <th>
                                <div class="filter-range">
                                    <input type="number" name="priceMin" value="{{ filters.priceMin }}" placeholder="Min" class="filter-input filter-input-half" min="0">
                                    <input type="number" name="priceMax" value="{{ filters.priceMax }}" placeholder="Max" class="filter-input filter-input-half" min="0">
                                </div>
                            </th>
                            <th>
                                <div class="filter-actions">
                                    <button type="submit" class="btn btn-primary btn-sm">{{ 'home.filter_submit'|trans }}</button>
                                    <a href="{{ path('app_home') }}" class="btn btn-secondary btn-sm">{{ 'home.filter_reset'|trans }}</a>
                                </div>
                            </th>
                        </tr>
                    </thead>
                    <tbody>
                        {% if products is empty %}
                            <tr>
                                <td colspan="5" class="empty-list">
                                    {% if hasFilters %}
                                        {{ 'home.no_results_filtered'|trans }}
                                    {% else %}
                                        {{ 'home.no_results_empty'|trans }}
                                    {% endif %}
                                </td>
                            </tr>
                        {% else %}
                            {% for product in products %}
                                {% if product.stock == 0 %}
                                    {% set rowClass = 'stock-out' %}
                                {% elseif product.stockMin is not null and product.stock <= product.stockMin %}
                                    {% set rowClass = 'stock-low' %}
                                {% else %}
                                    {% set rowClass = '' %}
                                {% endif %}
                                <tr class="{{ rowClass }}" onclick="window.location='{{ path('app_product_show', {id: product.id}) }}'">
                                    <td>
                                        <a class="product-name-link" href="{{ path('app_product_show', {id: product.id}) }}">
                                            {{ product.name }}
                                        </a>
                                    </td>
                                    <td>{{ product.category.name }}</td>
                                    <td>{{ product.stock }}</td>
                                    <td>{{ product.price }} €</td>
                                    <td>
                                        {{ product.description|slice(0, 100) }}{% if product.description|length > 100 %}…{% endif %}
                                    </td>
                                </tr>
                            {% endfor %}
                        {% endif %}
                    </tbody>
                </table>
        </form>

    </main>

</div>
{% endblock %}
