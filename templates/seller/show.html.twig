{% extends 'base.html.twig' %}

{% block title %}{{ seller.surname }} {{ seller.name }} — {{ 'product.meta_seller'|trans }}{% endblock %}

{% block body %}
<div class="home-container">
    <header class="home-header">
        <h1>{{ include('_brand.html.twig') }}</h1>
        <nav class="home-nav">
            {% if app.user %}
                <span>
                    {{ app.user.userIdentifier }}
                    {% if is_granted('ROLE_ADMIN') %}
                        <span class="badge-admin">{{ 'admin.role_admin'|trans }}</span>
                    {% endif %}
                </span>
                <a href="{{ path('app_profile') }}" class="btn btn-secondary">{{ 'nav.my_profile'|trans }}</a>
                <a href="{{ path('app_cart_show') }}" class="btn btn-secondary">{{ 'nav.my_cart'|trans }}</a>
                <a href="{{ path('app_logout') }}" class="btn btn-danger">{{ 'nav.logout'|trans }}</a>
            {% else %}
                <a href="{{ path('app_login') }}" class="btn btn-primary">{{ 'nav.login'|trans }}</a>
            {% endif %}
            {{ include('_controls.html.twig') }}
        </nav>
    </header>

    <div class="home-main">

    {% for message in app.flashes('success') %}
        <div class="flash-success">{{ message }}</div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div class="flash-error">{{ message }}</div>
    {% endfor %}

    <a href="{{ path('app_home') }}" class="btn-back">{{ 'seller.back_to_list'|trans }}</a>

    {# ── En-tête vendeur ── #}
    <div class="profile-card">
        <div class="seller-header">
            <div>
                <h2 class="profile-section-title" style="margin-bottom:.25rem;">
                    {{ seller.surname }} {{ seller.name }}
                </h2>
                <p style="color:var(--text-3);font-size:.9rem;margin:0;">{{ seller.email }}</p>
            </div>
            <div class="seller-rating-block">
                {% if averageRating is not null %}
                    <div class="seller-avg-stars">
                        {% for i in 1..5 %}
                            {% if i <= averageRating|round %}★{% else %}☆{% endif %}
                        {% endfor %}
                    </div>
                    <div class="seller-avg-num">{{ averageRating|number_format(1, ',') }} / 5 ({{ reviews|length }} {{ 'seller.review_label'|trans }})</div>
                {% else %}
                    <div class="seller-avg-num" style="color:var(--text-4);">{{ 'seller.no_reviews'|trans }}</div>
                {% endif %}
            </div>
        </div>
    </div>

    {# ── Annonces du vendeur ── #}
    <div class="profile-card">
        <h2 class="profile-section-title">{{ 'seller.listings_title_prefix'|trans }} ({{ products|length }})</h2>
        {% if products is empty %}
            <p class="profile-empty">{{ 'seller.no_listings'|trans }}</p>
        {% else %}
            <ul class="profile-list">
                {% for product in products %}
                    <li>
                        <a href="{{ path('app_product_show', {id: product.id}) }}">{{ product.name }}</a>
                        <span class="profile-list-meta">{{ product.price }} € — {{ product.category.name }}</span>
                    </li>
                {% endfor %}
            </ul>
        {% endif %}
    </div>

    {# ── Formulaire d'avis ── #}
    {% if app.user and app.user != seller %}
        <div class="profile-card">
            <h2 class="profile-section-title">
                {% if existingReview %}{{ 'seller.edit_review'|trans }}{% else %}{{ 'seller.write_review'|trans }}{% endif %}
            </h2>
            <form method="post" action="{{ path('app_review_add', {id: seller.id}) }}" class="review-form">
                <input type="hidden" name="_token" value="{{ csrf_token('review_add_' ~ seller.id) }}">
                <input type="hidden" name="redirect" value="seller">
                <input type="hidden" name="seller_id" value="{{ seller.id }}">

                <div class="form-group">
                    <label for="rating">{{ 'seller.rating_label'|trans }}</label>
                    <div class="star-rating">
                        {% for i in 5..1 %}
                            <input type="radio" id="star{{ i }}" name="rating" value="{{ i }}"
                                   {% if existingReview and existingReview.rating == i %}checked{% endif %}
                                   required>
                            <label for="star{{ i }}" title="{{ i }} étoile{{ i > 1 ? 's' : '' }}">★</label>
                        {% endfor %}
                    </div>
                </div>

                <div class="form-group">
                    <label for="comment">{{ 'seller.comment_label'|trans }}</label>
                    <textarea id="comment" name="comment" rows="4" required
                              placeholder="{{ 'seller.comment_placeholder'|trans }}">{{ existingReview ? existingReview.comment : '' }}</textarea>
                </div>

                <button type="submit" class="btn btn-primary">
                    {% if existingReview %}{{ 'seller.update_review'|trans }}{% else %}{{ 'seller.submit_review'|trans }}{% endif %}
                </button>
            </form>
        </div>
    {% endif %}

    {# ── Liste des avis ── #}
    <div class="profile-card">
        <h2 class="profile-section-title">{{ 'seller.reviews_received_prefix'|trans }} ({{ reviews|length }})</h2>

        {% if reviews is empty %}
            <p class="profile-empty">{{ 'seller.no_reviews_received'|trans }}</p>
        {% else %}
            <div class="reviews-list">
                {% for review in reviews %}
                    <div class="review-item">
                        <div class="review-header">
                            <div>
                                <span class="review-author">{{ review.author.surname }} {{ review.author.name }}</span>
                                <span class="review-date">{{ review.createdAt|date('d/m/Y') }}</span>
                            </div>
                            <div class="review-rating-stars">
                                {% for i in 1..5 %}
                                    {% if i <= review.rating %}★{% else %}☆{% endif %}
                                {% endfor %}
                                <span class="review-rating-num">({{ review.rating }}/5)</span>
                            </div>
                        </div>
                        <p class="review-comment">{{ review.comment }}</p>
                        <div class="review-actions">
                            {% if app.user and (review.author == app.user or is_granted('ROLE_ADMIN')) %}
                                <form method="post" action="{{ path('app_review_delete', {id: review.id}) }}"
                                      onsubmit="return confirm('{{ 'seller.confirm_delete_review'|trans }}')">
                                    <input type="hidden" name="_token" value="{{ csrf_token('review_delete_' ~ review.id) }}">
                                    <button type="submit" class="btn-review-delete">
                                        {% if is_granted('ROLE_ADMIN') and review.author != app.user %}
                                            {{ 'seller.delete_review_admin'|trans }}
                                        {% else %}
                                            {{ 'seller.delete_own_review'|trans }}
                                        {% endif %}
                                    </button>
                                </form>
                            {% endif %}
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>
    </div>
</div>
{% endblock %}
