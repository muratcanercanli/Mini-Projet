{% extends 'base.html.twig' %}

{% block title %}{{ 'admin.page_title'|trans }}{% endblock %}

{% block body %}
<div class="home-container">
    <header class="home-header">
        <h1 class="navbar-admin-title">{{ include('_brand.html.twig') }}<span class="navbar-section">{{ 'admin.section_label'|trans }}</span></h1>
        <nav class="home-nav">
            <span class="badge-admin">{{ 'admin.role_admin'|trans }}</span>
            <a href="{{ path('app_home') }}" class="btn btn-secondary">{{ 'nav.home'|trans }}</a>
            <a href="{{ path('app_profile') }}" class="btn btn-secondary">{{ 'nav.my_profile'|trans }}</a>
            <a href="{{ path('app_logout') }}" class="btn btn-danger">{{ 'nav.logout'|trans }}</a>
            {{ include('_controls.html.twig') }}
        </nav>
    </header>

    <div class="home-main">

        {% for message in app.flashes('success') %}
            <div class="flash-success">{{ message }}</div>
        {% endfor %}
        {% for message in app.flashes('error') %}
            <div class="flash-error">{{ message }}</div>
        {% endfor %}

        <div class="admin-section-header">
            <h2>{{ 'admin.users_management'|trans }}</h2>
            <span class="admin-count">{{ usersData|length }} {{ usersData|length != 1 ? 'admin.user_plural'|trans : 'admin.user_singular'|trans }}</span>
        </div>

        <table class="product-table admin-table">
            <thead>
                <tr>
                    <th>{{ 'admin.col_user'|trans }}</th>
                    <th>{{ 'admin.col_email'|trans }}</th>
                    <th>{{ 'admin.col_role'|trans }}</th>
                    <th>{{ 'admin.col_products'|trans }}</th>
                    <th>{{ 'admin.col_reviews_received'|trans }}</th>
                    <th>{{ 'admin.col_avg_rating'|trans }}</th>
                    <th>{{ 'admin.col_actions'|trans }}</th>
                </tr>
            </thead>
            <tbody>
                {% for data in usersData %}
                    {% set user = data.user %}
                    <tr>
                        <td>
                            <a href="{{ path('app_admin_user_detail', {id: user.id}) }}" class="product-name-link">
                                {{ user.surname }} {{ user.name }}
                            </a>
                        </td>
                        <td style="color:var(--text-3); font-size:.9rem;">{{ user.email }}</td>
                        <td>
                            {% if 'ROLE_ADMIN' in user.roles %}
                                <span class="badge-admin">{{ 'admin.role_admin'|trans }}</span>
                            {% else %}
                                <span class="badge-user">{{ 'admin.role_member'|trans }}</span>
                            {% endif %}
                        </td>
                        <td>{{ user.products|length }}</td>
                        <td>{{ user.receivedReviews|length }}</td>
                        <td>
                            {% if data.averageRating is not null %}
                                <span class="admin-rating">
                                    {{ data.averageRating|number_format(1, ',') }}/5
                                    {% for i in 1..5 %}{% if i <= data.averageRating|round %}★{% else %}☆{% endif %}{% endfor %}
                                </span>
                            {% else %}
                                <span style="color:var(--text-4);">—</span>
                            {% endif %}
                        </td>
                        <td class="admin-actions-cell">
                            <a href="{{ path('app_admin_user_detail', {id: user.id}) }}" class="btn btn-secondary btn-sm">{{ 'admin.btn_view'|trans }}</a>
                            {% if user != app.user %}
                                <form method="post" action="{{ path('app_admin_user_delete', {id: user.id}) }}"
                                      onsubmit="return confirm('{{ 'admin.confirm_delete_user'|trans({'%name%': user.surname ~ ' ' ~ user.name}) }}')">
                                    <input type="hidden" name="_token" value="{{ csrf_token('admin_user_delete_' ~ user.id) }}">
                                    <button type="submit" class="btn btn-danger btn-sm">{{ 'admin.btn_delete'|trans }}</button>
                                </form>
                            {% else %}
                                <span style="color:var(--text-4); font-size:.8rem;">{{ 'admin.you'|trans }}</span>
                            {% endif %}
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>

    </div>
</div>
{% endblock %}
