{% extends 'base.html.twig' %}

{% block title %}{{ 'product.edit.heading'|trans }} — {{ product.name }}{% endblock %}

{% block body %}
<div class="home-container">
    <header class="home-header">
        <h1>{{ include('_brand.html.twig') }}</h1>
        <nav class="home-nav">
            <a href="{{ path('app_product_show', {id: product.id}) }}" class="btn-secondary">{{ 'product.edit.back'|trans }}</a>
            {{ include('_controls.html.twig') }}
        </nav>
    </header>

    <div class="home-main">
    <div class="form-card">
        <h2 class="form-card-title">{{ 'product.edit.heading'|trans }}</h2>
        <p class="form-card-subtitle">{{ product.name }}</p>

        {% for message in app.flashes('error') %}
            <div class="flash-error">{{ message }}</div>
        {% endfor %}

        {{ form_start(form, { attr: { novalidate: 'novalidate' } }) }}
            {% include 'product/_form.html.twig' %}
            <button type="submit" class="btn-submit">{{ 'product.edit.submit'|trans }}</button>
        {{ form_end(form) }}
    </div>
    </div>
</div>
{% endblock %}
