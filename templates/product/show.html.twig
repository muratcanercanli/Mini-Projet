{% extends 'base.html.twig' %}

{% block title %}{{ product.name }}{% endblock %}

{% block body %}
<div class="home-container">
    <header class="home-header">
        <h1>{{ include('_brand.html.twig') }}</h1>
        <nav class="home-nav">
            {% if app.user %}
                <span>
                    {{ app.user.userIdentifier }}
                    {% if is_granted('ROLE_ADMIN') %}
                        <span class="badge-admin">{{ 'admin.role_admin'|trans }}</span>
                    {% endif %}
                </span>
                <a href="{{ path('app_profile') }}" class="btn btn-secondary">{{ 'nav.my_profile'|trans }}</a>
                <a href="{{ path('app_logout') }}" class="btn btn-danger">{{ 'nav.logout'|trans }}</a>
            {% else %}
                <a href="{{ path('app_login') }}" class="btn btn-primary">{{ 'nav.login'|trans }}</a>
            {% endif %}
            {{ include('_controls.html.twig') }}
        </nav>
    </header>

    <div class="home-main">

    {% for message in app.flashes('success') %}
        <div class="flash-success">{{ message }}</div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div class="flash-error">{{ message }}</div>
    {% endfor %}

    <a href="{{ path('app_home') }}" class="btn-back">{{ 'product.back_to_list'|trans }}</a>

    <div class="product-show">

        <div class="product-show-header">
            <div>
                <h2 class="product-show-title">{{ product.name }}</h2>
                <span class="badge badge-category">{{ product.category.name }}</span>
            </div>
            <div class="product-show-price-block">
                <div class="product-price">{{ product.price }} €</div>

                {% if product.stock == 0 %}
                    <span class="badge badge-stock-out">{{ 'product.out_of_stock'|trans }}</span>
                {% elseif product.stockMin is not null and product.stock <= product.stockMin %}
                    <span class="badge badge-stock-low">{{ 'product.low_stock'|trans }} ({{ product.stock }} {{ product.stock > 1 ? 'product.remaining_plural'|trans : 'product.remaining_singular'|trans }})</span>
                {% else %}
                    <span class="badge badge-stock-ok">{{ 'product.in_stock'|trans({'%count%': product.stock}) }}</span>
                {% endif %}
            </div>
        </div>

        <p class="product-description">{{ product.description }}</p>

        <dl class="product-meta">
            <dt>{{ 'product.meta_seller'|trans }}</dt>
            <dd>
                {% if product.seller %}
                    <a href="{{ path('app_seller_profile', {id: product.seller.id}) }}" style="color:#6366f1;font-weight:600;text-decoration:none;">
                        {{ product.seller.name }} {{ product.seller.surname }}
                    </a>
                {% else %}
                    <em>{{ 'product.meta_not_provided'|trans }}</em>
                {% endif %}
            </dd>

            <dt>{{ 'product.meta_seller_contact'|trans }}</dt>
            <dd>
                {% if product.seller %}
                    {{ product.seller.email }}
                {% else %}
                    —
                {% endif %}
            </dd>

            <dt>{{ 'product.meta_stock_min'|trans }}</dt>
            <dd>{{ product.stockMin ?? '—' }}</dd>

            <dt>{{ 'product.meta_published_on'|trans }}</dt>
            <dd>{{ product.creationDate|date('d/m/Y') }}</dd>

            <dt>{{ 'product.meta_last_modified'|trans }}</dt>
            <dd>{{ product.modificationDate|date('d/m/Y') }}</dd>
        </dl>

        {% if app.user and product.stock > 0 and product.seller != app.user %}
            <div class="product-actions" style="margin-bottom:1rem;">
                <form method="post" action="{{ path('app_cart_add', {id: product.id}) }}" class="cart-add-form">
                    <input type="hidden" name="_token" value="{{ csrf_token('cart_add_' ~ product.id) }}">
                    <label for="qty-{{ product.id }}" style="font-size:.875rem;font-weight:600;color:var(--text-2);">{{ 'product.quantity_label'|trans }}</label>
                    <input type="number" id="qty-{{ product.id }}" name="quantity" value="1" min="1" max="{{ product.stock }}" class="cart-qty-input">
                    <button type="submit" class="btn btn-primary">{{ 'product.add_to_cart'|trans }}</button>
                </form>
                <a href="{{ path('app_cart_show') }}" class="btn btn-secondary">{{ 'product.view_cart'|trans }}</a>
            </div>
        {% elseif app.user and product.stock == 0 %}
            <div class="product-actions" style="margin-bottom:1rem;">
                <span class="badge badge-stock-out" style="font-size:.9rem;padding:.4rem 1rem;">{{ 'product.out_of_stock'|trans }}</span>
            </div>
        {% endif %}

        {% if app.user and product.seller != app.user %}
            {% set isFavorite = app.user.listFavorites.contains(product) %}
            <div class="product-actions" style="margin-bottom:1rem;">
                <form method="post" action="{{ path('app_favorite_toggle', {id: product.id}) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('favorite_toggle_' ~ product.id) }}">
                    <input type="hidden" name="redirect" value="product">
                    <button type="submit" class="btn-favorite {% if isFavorite %}btn-favorite--active{% endif %}">
                        {% if isFavorite %}{{ 'product.remove_favorite'|trans }}{% else %}{{ 'product.add_favorite'|trans }}{% endif %}
                    </button>
                </form>
            </div>
        {% endif %}

        {% if app.user and (product.seller == app.user or is_granted('ROLE_ADMIN')) %}
            <div class="product-actions">
                <a href="{{ path('app_product_edit', {id: product.id}) }}" class="btn btn-primary">
                    {{ 'product.edit'|trans }}
                </a>

                <form method="post" action="{{ path('app_product_delete', {id: product.id}) }}"
                      onsubmit="return confirm('{{ 'product.confirm_delete'|trans }}')">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ product.id) }}">
                    <button type="submit" class="btn btn-danger">{{ 'product.delete'|trans }}</button>
                </form>
            </div>
        {% endif %}

    </div>
    </div>
</div>
{% endblock %}
