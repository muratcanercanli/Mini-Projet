{# Bouton toggle thème + sélecteur de langue — à inclure dans chaque navbar #}
<button id="theme-toggle" class="btn-theme-toggle" aria-label="{{ 'controls.toggle_theme'|trans }}">
    {# Soleil : visible quand data-theme="dark" (pour repasser en clair) #}
    <svg class="theme-icon icon-sun" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="12" cy="12" r="5"/>
        <line x1="12" y1="1" x2="12" y2="3"/>
        <line x1="12" y1="21" x2="12" y2="23"/>
        <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
        <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
        <line x1="1" y1="12" x2="3" y2="12"/>
        <line x1="21" y1="12" x2="23" y2="12"/>
        <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
        <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
    </svg>
    {# Lune : visible par défaut (mode clair) #}
    <svg class="theme-icon icon-moon" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
    </svg>
</button>

<div class="lang-switcher">
    {# data-turbo="false" force un rechargement complet, nécessaire pour appliquer la locale #}
    <a href="{{ path('app_switch_locale', {locale: 'fr'}) }}"
       class="lang-btn {% if app.request.locale == 'fr' %}lang-btn--active{% endif %}"
       title="Français"
       data-turbo="false">FR</a>
    <a href="{{ path('app_switch_locale', {locale: 'en'}) }}"
       class="lang-btn {% if app.request.locale == 'en' %}lang-btn--active{% endif %}"
       title="English"
       data-turbo="false">EN</a>
</div>
