{% extends 'base.html.twig' %}

{% block title %}Créer un compte{% endblock %}

{% block body %}
<div class="register-wrapper">
    <div class="register-card">
        {{ include('_brand.html.twig', {brand_class: 'card-brand'}) }}
        <h1>Créer un compte</h1>

        {% for message in app.flashes('success') %}
            <div class="alert alert-success">{{ message }}</div>
        {% endfor %}

        {% for message in app.flashes('error') %}
            <div class="alert alert-error">{{ message }}</div>
        {% endfor %}

        {{ form_start(form, { attr: { novalidate: 'novalidate' } }) }}

            <div class="form-row">
                <div class="form-group">
                    {{ form_label(form.name) }}
                    {{ form_widget(form.name, { attr: { placeholder: 'Jean' } }) }}
                    {{ form_errors(form.name) }}
                </div>
                <div class="form-group">
                    {{ form_label(form.surname) }}
                    {{ form_widget(form.surname, { attr: { placeholder: 'Dupont' } }) }}
                    {{ form_errors(form.surname) }}
                </div>
            </div>

            <div class="form-group">
                {{ form_label(form.email) }}
                {{ form_widget(form.email, { attr: { placeholder: 'email@exemple.com' } }) }}
                {{ form_errors(form.email) }}
            </div>

            <div class="form-group">
                {{ form_label(form.address) }}
                {{ form_widget(form.address, { attr: { placeholder: '1 rue de la Paix, 75001 Paris' } }) }}
                {{ form_errors(form.address) }}
            </div>

            <div class="form-group">
                {{ form_label(form.phoneNumber) }}
                {{ form_widget(form.phoneNumber, { attr: { placeholder: '06 12 34 56 78' } }) }}
                {{ form_errors(form.phoneNumber) }}
            </div>

            <div class="form-group">
                {{ form_label(form.plainPassword.first) }}
                {{ form_widget(form.plainPassword.first, { attr: { placeholder: '••••••••' } }) }}
                {{ form_errors(form.plainPassword.first) }}
            </div>

            <div class="form-group">
                {{ form_label(form.plainPassword.second) }}
                {{ form_widget(form.plainPassword.second, { attr: { placeholder: '••••••••' } }) }}
                {{ form_errors(form.plainPassword.second) }}
                {{ form_errors(form.plainPassword) }}
            </div>

            <button type="submit" class="btn-submit">Créer mon compte</button>

        {{ form_end(form) }}

        <p class="login-link">
            Déjà inscrit ? <a href="{{ path('app_login') }}">Se connecter</a>
        </p>
    </div>
</div>

<style>
    body {
        margin: 0;
        font-family: sans-serif;
        background: #f0f2f5;
    }

    .register-wrapper {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        padding: 2rem 1rem;
    }

    .register-card {
        background: #fff;
        border-radius: 8px;
        box-shadow: 0 2px 16px rgba(0,0,0,.10);
        padding: 2.5rem 2rem;
        width: 100%;
        max-width: 520px;
    }

    h1 {
        margin: 0 0 1.5rem;
        font-size: 1.6rem;
        text-align: center;
        color: #1a1a2e;
    }

    .alert {
        border-radius: 4px;
        padding: .75rem 1rem;
        margin-bottom: 1rem;
        font-size: .9rem;
    }

    .alert-success {
        background: #d1fae5;
        color: #065f46;
        border: 1px solid #a7f3d0;
    }

    .alert-error {
        background: #fde8e8;
        color: #c0392b;
        border: 1px solid #f5c6c6;
    }

    .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0 1rem;
    }

    .form-group {
        margin-bottom: 1.1rem;
        display: flex;
        flex-direction: column;
    }

    .form-group label {
        font-size: .875rem;
        font-weight: 600;
        color: #374151;
        margin-bottom: .35rem;
    }

    .form-group input {
        padding: .6rem .75rem;
        border: 1px solid #d1d5db;
        border-radius: 5px;
        font-size: 1rem;
        transition: border-color .2s;
    }

    .form-group input:focus {
        outline: none;
        border-color: #6366f1;
        box-shadow: 0 0 0 3px rgba(99,102,241,.15);
    }

    .form-group ul {
        margin: .3rem 0 0;
        padding: 0;
        list-style: none;
        color: #c0392b;
        font-size: .8rem;
    }

    .btn-submit {
        width: 100%;
        padding: .7rem;
        background: #6366f1;
        color: #fff;
        border: none;
        border-radius: 5px;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        transition: background .2s;
        margin-top: .5rem;
    }

    .btn-submit:hover {
        background: #4f46e5;
    }

    .login-link {
        text-align: center;
        margin-top: 1.25rem;
        font-size: .875rem;
        color: #6b7280;
    }

    .login-link a {
        color: #6366f1;
        text-decoration: none;
        font-weight: 600;
    }

    .login-link a:hover {
        text-decoration: underline;
    }
</style>
{% endblock %}
