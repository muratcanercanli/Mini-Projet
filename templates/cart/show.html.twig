{% extends 'base.html.twig' %}

{% block title %}Mon panier - Boutique{% endblock %}

{% block body %}
<div class="home-container">
    <header class="home-header">
        <h1>Boutique en ligne</h1>
        <nav class="home-nav">
            <span>{{ app.user.userIdentifier }}</span>
            <a href="{{ path('app_home') }}" class="btn btn-secondary">Continuer mes achats</a>
            <a href="{{ path('app_logout') }}" class="btn btn-danger">Se déconnecter</a>
        </nav>
    </header>

    {# Flash messages #}
    {% for message in app.flashes('success') %}
        <div class="flash-success">{{ message }}</div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div class="flash-error">{{ message }}</div>
    {% endfor %}

    <main>
        <h2>Mon panier</h2>

        {% if cart is null or cart.cartItems is empty %}
            <p class="empty-list">Votre panier est vide.</p>
            <a href="{{ path('app_home') }}" class="btn btn-primary">Voir les articles</a>
        {% else %}
            <table class="product-table">
                <thead>
                    <tr>
                        <th>Article</th>
                        <th>Catégorie</th>
                        <th>Prix unitaire</th>
                        <th>Quantité</th>
                        <th>Sous-total</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    {% for item in cart.cartItems %}
                        <tr>
                            <td>
                                <a class="product-name-link" href="{{ path('app_product_show', {id: item.product.id}) }}">
                                    {{ item.product.name }}
                                </a>
                                {% if item.quantity > item.product.stock %}
                                    <span class="badge badge-stock-out" style="display:inline-block;margin-left:.4rem;">Stock insuffisant</span>
                                {% endif %}
                            </td>
                            <td>{{ item.product.category.name }}</td>
                            <td>{{ item.product.price }} €</td>
                            <td>
                                <form method="post" action="{{ path('app_cart_update_quantity', {id: item.id}) }}" class="cart-qty-form">
                                    <input type="hidden" name="_token" value="{{ csrf_token('cart_qty_' ~ item.id) }}">
                                    <input type="number"
                                           name="quantity"
                                           value="{{ item.quantity }}"
                                           min="0"
                                           max="{{ item.product.stock }}"
                                           class="cart-qty-input"
                                           onchange="this.form.submit()">
                                </form>
                            </td>
                            <td class="cart-subtotal">{{ item.product.price * item.quantity }} €</td>
                            <td>
                                <form method="post" action="{{ path('app_cart_remove_item', {id: item.id}) }}">
                                    <input type="hidden" name="_token" value="{{ csrf_token('cart_remove_' ~ item.id) }}">
                                    <button type="submit" class="btn-remove" title="Retirer" onclick="return confirm('Retirer cet article du panier ?')">✕</button>
                                </form>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
                <tfoot>
                    <tr class="cart-total-row">
                        <td colspan="4" class="cart-total-label">Total</td>
                        <td colspan="2" class="cart-total-value">{{ cart.total }} €</td>
                    </tr>
                </tfoot>
            </table>

            <div class="cart-actions">
                <form method="post" action="{{ path('app_cart_checkout') }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('cart_checkout') }}">
                    <button type="submit" class="btn btn-primary btn-checkout"
                            onclick="return confirm('Confirmer la commande ?')">
                        Valider la commande
                    </button>
                </form>
            </div>
        {% endif %}
    </main>
</div>
{% endblock %}
